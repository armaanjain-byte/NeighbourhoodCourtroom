# ── Provider chain (tries left-to-right; falls back to deterministic if ALL fail) ──
LLM_PROVIDER_CHAIN=gemini,groq,openrouter

# Drop your API keys below — only the providers you configure will be used
GEMINI_API_KEY=your-gemini-api-key-here
GROQ_API_KEY=your-groq-api-key-here
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Single-provider fallback (used only if LLM_PROVIDER_CHAIN is not set)
LLM_PROVIDER=gemini
# Note: For OpenRouter, the default model is "openrouter/free" (Free Models Router).
# Empirical Success Rate: 60.0% first-attempt success (valid structured JSON + tool calls without nudge),
# and 100% overall success rate after a single nudge-retry.
# OPENAI_API_KEY=your-openai-api-key-here
